# 이 파일을 복사해 같은 폴더에 `.env.local` 로 저장한 뒤, 값만 채우세요.
# `.env.local` 은 Git에 커밋하지 마세요 (.gitignore 에 포함되는 것이 일반적입니다).
#
# Vercel에만 넣어 두었다면: Dashboard → Project → Settings → Environment Variables
# 에서 이름을 그대로 복사해 아래에 붙여 넣으면 됩니다. `vercel dev` 가 로컬에서 이 파일을 읽습니다.

# --- Supabase (앱·관리자 목록 조회, /api/env 로 anon 만 브라우저에 전달) ---
# 아래 둘 중 한 세트면 됩니다.
SUPABASE_PROJECT_ID=
SUPABASE_ANON_KEY=
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...

# --- 관리자 API (/admin 에서 추가·삭제) — 서버에서만 사용, 브라우저에 노출되지 않음 ---
# Vercel Production 에 넣은 것과 동일한 값을 로컬에서도 쓰려면 여기에 복사하세요.
OX_ADMIN_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# --- 선택: 도구 스크립트 등 ---
# OPENAI_API_KEY=
